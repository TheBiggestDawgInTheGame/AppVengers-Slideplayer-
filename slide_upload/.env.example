# ═══════════════════════════════════════════════════════════════════════════
#  SlidePlay — combined server environment variables
#  Copy this file to .env (same folder) and fill in your real values.
#  Lines starting with # are comments — safe to leave as-is.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000

# ─── Multiplayer scaling (Socket.IO) ───────────────────────────────────────
# Enable Redis adapter for multi-instance hosting (recommended in production)
SOCKET_IO_USE_REDIS=true
# Fail deployment readiness checks unless Redis multiplayer is actually connected
SOCKET_IO_REQUIRE_REDIS=false
# Example: redis://default:password@redis-host:6379
SOCKET_IO_REDIS_URL=

# ─── Google Gemini (AI quiz generation + RAG study mode) ────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Groq (primary text AI + optional vision fallback) ──────────────────────
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# ─── Hugging Face (fallback quiz generation) ────────────────────────────────
# Get a token at https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=
# HUGGING_FACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ─── Firebase Admin SDK ─────────────────────────────────────────────────────
# Realtime Database URL — found in Firebase Console → Realtime Database
FIREBASE_DB_URL=https://slideplayer-d024f-default-rtdb.firebaseio.com/
# The service account JSON file is read from:
#   finsished front end/Testing2-SlidePlay/firebase-service-account.json
# No extra env var needed — just make sure that file exists.

# ─── SQL Server (SLIDEPLAYDB) ────────────────────────────────────────────────
DB_SERVER=DESKTOP-734DTIS
DB_NAME=SLIDEPLAYDB
DB_USER=
DB_PASSWORD=
# DB_PORT=1433

# ─── Teacher registration code ──────────────────────────────────────────────
TEACHER_CODE=SLIDETEACH

# ─── SendGrid (transactional email) ─────────────────────────────────────────
# Get an API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# ─── PayFast (ZAR card payments) ────────────────────────────────────────────
# Sandbox credentials: https://developers.payfast.co.za/docs#testing
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# Set to "false" once you go live:
PAYFAST_SANDBOX=true
# Override the PayFast endpoint URL (leave blank to use the default)
# PAYFAST_URL=https://www.payfast.co.za/eng/process

# ─── Coinbase Commerce (crypto payments) ────────────────────────────────────
# Dashboard: https://commerce.coinbase.com/
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=
